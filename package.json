{
  "name": "pomodoro-extension",
  "version": "1.0.0",
  "description": "Premium Pomodoro WebExtension with a GitHub-style activity graph",
  "main": "background.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{js,json,css,html,md}'",
    "format:check": "prettier --check '**/*.{js,json,css,html,md}'",
    "check": "eslint . && prettier --check '**/*.{js,json,css,html,md}'"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^14.12.0",
    "prettier": "^3.8.4",
    "vitest": "^1.6.0"
  }
}
